---
import BaseLayout from '@/layouts/base-layout.astro'
import { docHref, getDocs, groupDocs, withBase } from '@/lib/site'

const docs = await getDocs()
const groups = groupDocs(docs)
const description =
  'An OpenClaw-style personal agent built directly into Pi, with a living home and warmth pass that keep its voice intact.'
---

<BaseLayout description={description}>
  <main id="main-content" class="site-shell home-page" tabindex="-1">
    <header class="hero">
      <div class="hero-copy">
        <p class="kicker">OpenClaw-ish. Still Pi.</p>
        <h1>Make the Clankers speak hooman.</h1>
        <p class="lede">
          Clawa brings the personal-agent experience I wanted from OpenClaw into normal Pi. Its
          living home and bundled warmth pass keep capable models from waking up as the same
          laminated assistant every session.
        </p>
        <div class="hero-links">
          <a class="primary-link" href={withBase('/docs/getting-started/installation/')}>Install pi-clawa</a>
          <a href={withBase('/docs/reference/runtime/')}>Trace the runtime</a>
        </div>
      </div>
      <figure class="hero-media">
        <img src={withBase('/images/clawa-keyboard.webp')} width="1024" height="1024" alt="Howaclawa mashing at a keyboard in a neon workshop" />
      </figure>
    </header>

    <section class="docs-index" aria-label="Documentation index">
      {Array.from(groups).map(([section, entries]) => (
        <section class="docs-group">
          <h2>{section}</h2>
          <div class="docs-rows">
            {entries.map((entry) => (
              <a class="doc-row" href={docHref(entry)}>
                <strong>{entry.data.title}</strong>
                <span>{entry.data.description}</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </section>

  </main>
</BaseLayout>
