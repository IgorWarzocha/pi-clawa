{
  "name": "@howaboua/pi-clawa",
  "version": "0.0.0",
  "type": "module",
  "description": "Redistributable Pi extension package for the Clawa/Clawas runtime.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "clawas",
    "clawa"
  ],
  "scripts": {
    "typecheck": "tsgo --noEmit --noCheck",
    "typecheck:strict": "tsgo --noEmit",
    "test": "node --import tsx --test tests/*.test.ts src/clawas/session-registry.test.ts src/clawas/comms/*.test.ts packages/pi-clawa-discord/smoke.test.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:strict": "biome check --error-on-warnings .",
    "knip": "knip",
    "deadcode": "knip",
    "ai:check": "biome check . && tsgo --noEmit --noCheck && (cd packages/pi-clawa-discord && bun run typecheck:gateway) && knip && node --import tsx --test tests/*.test.ts src/clawas/session-registry.test.ts src/clawas/comms/*.test.ts packages/pi-clawa-discord/smoke.test.ts",
    "ai:check:strict": "biome check --error-on-warnings . && tsgo --noEmit && (cd packages/pi-clawa-discord && bun run typecheck:gateway) && knip && node --import tsx --test tests/*.test.ts src/clawas/session-registry.test.ts src/clawas/comms/*.test.ts packages/pi-clawa-discord/smoke.test.ts",
    "check": "bun run ai:check"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "files": [
    "README.md",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "templates/**",
    "skills/**",
    "install/**",
    "scripts/**"
  ],
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*",
    "@earendil-works/pi-ai": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@earendil-works/pi-agent-core": "0.79.6",
    "@earendil-works/pi-coding-agent": "0.79.6",
    "@earendil-works/pi-tui": "0.79.6",
    "@types/node": "25.9.2",
    "tsx": "^4.20.0",
    "typebox": "1.2.8",
    "typescript": "^6.0.3",
    "@typescript/native-preview": "7.0.0-dev.20260610.1",
    "knip": "6.12.1",
    "@earendil-works/pi-ai": "0.79.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24.15.0 <27"
  },
  "workspaces": [
    "packages/*"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts",
    "./jsonc": "./src/jsonc.ts",
    "./clawas/comms/message-extract": "./src/clawas/comms/message-extract.ts",
    "./clawas/comms/outbound": "./src/clawas/comms/outbound.ts",
    "./clawas/comms/report-back-helpers": "./src/clawas/comms/report-back-helpers.ts",
    "./clawas/comms/types": "./src/clawas/comms/types.ts",
    "./clawas/config-loader": "./src/clawas/config-loader.ts"
  }
}
