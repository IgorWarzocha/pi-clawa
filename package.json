{
  "name": "@howaboua/pi-clawa",
  "version": "0.1.0",
  "type": "module",
  "description": "Redistributable Pi extension package for the Clawa/Clawas runtime.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "clawas",
    "clawa"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit --noCheck",
    "typecheck:strict": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts src/clawas/*.test.ts src/clawas/comms/*.test.ts packages/pi-clawa-discord/*.test.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:strict": "biome check --error-on-warnings .",
    "knip": "knip",
    "deadcode": "knip",
    "docs:dev": "bun --cwd website dev",
    "docs:build": "bun --cwd website build",
    "ai:check": "biome check . && tsc --noEmit --noCheck && (cd packages/pi-clawa-discord && bun run typecheck:gateway) && knip && node --import tsx --test tests/*.test.ts src/clawas/*.test.ts src/clawas/comms/*.test.ts packages/pi-clawa-discord/*.test.ts && bun run docs:build",
    "ai:check:strict": "biome check --error-on-warnings . && tsc --noEmit && (cd packages/pi-clawa-discord && bun run typecheck:gateway) && knip && node --import tsx --test tests/*.test.ts src/clawas/*.test.ts src/clawas/comms/*.test.ts packages/pi-clawa-discord/*.test.ts && bun run docs:build",
    "check": "bun run ai:check"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "files": [
    "README.md",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "templates/**",
    "skills/**",
    "!skills/**/__pycache__/**",
    "!skills/**/*.pyc",
    "!skills/**/*.pyo",
    "install/**",
    "scripts/**"
  ],
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*",
    "@earendil-works/pi-ai": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@earendil-works/pi-agent-core": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@earendil-works/pi-tui": "0.80.6",
    "@types/node": "26.1.1",
    "tsx": "^4.23.1",
    "typebox": "1.3.6",
    "typescript": "7.0.2",
    "knip": "6.26.0",
    "@earendil-works/pi-ai": "0.80.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24.15.0 <27"
  },
  "workspaces": [
    "packages/*",
    "website"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts",
    "./jsonc": "./src/jsonc.ts",
    "./clawas/comms/message-extract": "./src/clawas/comms/message-extract.ts",
    "./clawas/comms/outbound": "./src/clawas/comms/outbound.ts",
    "./clawas/comms/report-back-helpers": "./src/clawas/comms/report-back-helpers.ts",
    "./clawas/comms/types": "./src/clawas/comms/types.ts",
    "./clawas/config-loader": "./src/clawas/config-loader.ts"
  }
}
