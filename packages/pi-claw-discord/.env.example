# Clawa Discord adapter config

# Required
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Project-local Pi/Clawa configuration
PI_BIN=pi
PI_CWD=/path/to/project
PI_EXTRA_FLAGS=
PI_CLAWAS_CONTROL_SOCKET_DIR=clawas/control

# Map Discord channels to CLAWAS workers.
# Example: CLAWAS_CHANNEL_WORKERS=123456789012345678=discord-clawa
CLAWAS_CHANNEL_WORKERS=

# Gateway behavior
TRIGGER_NAME=clawa
TRIGGER_ALIASES=claw,clawa
CHANNEL_POLICY=allowlist
MAX_CONCURRENCY=3
POLL_INTERVAL_MS=1000
SHUTDOWN_TIMEOUT_MS=15000
AUTO_REGISTER_DMS=true
MAX_ATTACHMENT_BYTES=26214400
MAX_TOTAL_ATTACHMENT_BYTES=52428800

# Project-local storage
SESSIONS_DIR=.pi/claw-discord/sessions
DB_PATH=.pi/claw-discord/gateway.db

# Logging
LOG_LEVEL=info
