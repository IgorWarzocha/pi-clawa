{
  "name": "@howaboua/pi-clawa-discord",
  "version": "0.0.0",
  "type": "module",
  "description": "Discord adapter package for @howaboua/pi-claw.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "clawa",
    "discord"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "README.md",
    "DISCORD-BOT-SETUP.md",
    "LICENSE",
    "NOTICE.md",
    ".env.example",
    "index.ts",
    "src/**",
    "templates/**",
    "install/**",
    "tsconfig.gateway.json"
  ],
  "exports": {
    ".": "./index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "better-sqlite3": "^12.0.0",
    "croner": "^10.0.1",
    "discord.js": "^14.18.0",
    "dotenv": "^16.5.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.20.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*",
    "@howaboua/pi-claw": "*"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "25.9.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.15.0 <27"
  },
  "peerDependenciesMeta": {
    "@howaboua/pi-claw": {
      "optional": true
    }
  },
  "scripts": {
    "typecheck:gateway": "tsgo --noEmit -p tsconfig.gateway.json",
    "check": "bun run typecheck:gateway"
  }
}
