{
  "name": "@howaboua/pi-clawa-discord",
  "version": "0.1.0",
  "type": "module",
  "description": "Discord adapter package for @howaboua/pi-clawa.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "clawa",
    "discord"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "README.md",
    "DISCORD-BOT-SETUP.md",
    "LICENSE",
    "NOTICE.md",
    ".env.example",
    "index.ts",
    "src/**",
    "templates/**",
    "tsconfig.gateway.json"
  ],
  "exports": {
    ".": "./index.ts"
  },
  "dependencies": {
    "@howaboua/pi-clawa": "link:.",
    "better-sqlite3": "^12.11.1",
    "discord.js": "^14.26.5",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*",
    "@howaboua/pi-clawa": "*"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "26.1.1",
    "typescript": "7.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.15.0 <27"
  },
  "peerDependenciesMeta": {
    "@howaboua/pi-clawa": {
      "optional": true
    }
  },
  "scripts": {
    "typecheck:gateway": "tsc --noEmit -p tsconfig.gateway.json",
    "check": "bun run typecheck:gateway"
  }
}
