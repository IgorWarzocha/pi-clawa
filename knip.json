{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["tests/*.test.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    }
  },
  "ignoreIssues": {
    "src/config.ts": ["exports"],
    "src/gui-primitives.ts": ["types"],
    "src/clawas/**/*.ts": ["exports", "types"],
    "packages/pi-clawa-discord/index.ts": ["exports"]
  },
  "ignore": ["packages/pi-clawa-discord/src/gateway/**"],
  "ignoreDependencies": ["pino-pretty", "tsx"]
}
