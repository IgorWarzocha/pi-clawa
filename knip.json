{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["**/*.test.ts"],
      "project": ["**/*.ts"]
    }
  },
  "ignoreIssues": {
    "config.ts": ["exports"],
    "gui-primitives.ts": ["types"],
    "clawas/**/*.ts": ["exports", "types"],
    "packages/pi-claw-discord/index.ts": ["exports"]
  },
  "ignore": ["packages/pi-claw-discord/src/gateway/**"],
  "ignoreDependencies": [
    "@clack/prompts",
    "better-sqlite3",
    "croner",
    "pino",
    "pino-pretty",
    "tsx",
    "@types/better-sqlite3",
    "@howaboua/pi-claw"
  ]
}
